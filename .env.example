# Character Keeper — environment configuration
# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# ── Required ────────────────────────────────────────────────────────────────
# Signing key for session cookies. REQUIRED in production — the server refuses
# to boot without it. Generate a strong value with:
#   openssl rand -hex 32
SESSION_SECRET=

# Set to "production" for any real deployment (enables secure cookies, HSTS,
# and the SESSION_SECRET hard-requirement above).
NODE_ENV=production

# ── Networking ───────────────────────────────────────────────────────────────
# Port the server listens on (default: 3001).
PORT=3001

# Cross-origin allowlist. LEAVE UNSET in production — the frontend is served
# same-origin so no CORS is needed. Only set in dev if the React dev server
# (e.g. http://localhost:3000) needs to reach the API directly.
CORS_ORIGINS=

# ── Storage & bundles ────────────────────────────────────────────────────────
# Root directory for runtime data: users, characters, campaigns, settings.
# Default: ./data relative to the app root. Mount as a persistent volume.
DATA_DIR=./data

# Live game-system bundle directory. Default: <DATA_DIR>/sheets. In Docker this
# is typically a mounted volume (e.g. /bundles). Built-in bundles are seeded
# here on first launch from SEED_BUNDLES_DIR if the directory is empty.
BUNDLES_DIR=

# Read-only source for the built-in bundles, copied into BUNDLES_DIR on first
# run. Default: /app/seed-bundles (baked into the Docker image). No need to
# set this unless you're overriding the default bundle set.
SEED_BUNDLES_DIR=

# ── Security toggles ─────────────────────────────────────────────────────────
# All default to the safe/no-change value so upgrades are non-breaking.
# Enable them once you've verified the app works correctly in your environment.

# CSRF: reject state-changing requests without a valid synchronizer token.
# The frontend sends the token automatically via a global fetch interceptor.
# Recommended TRUE for all networked deployments.
CSRF_ENFORCE=true

# CSP: enforce the Content-Security-Policy header (default: report-only).
# Before enabling: deploy in report-only mode, watch the browser console for
# violations, and drive them to zero. Also rebuild the frontend with
# INLINE_RUNTIME_CHUNK=false before setting CSP_INLINE_SCRIPT=false.
CSP_ENFORCE=false

# Drop 'unsafe-inline' from the script-src CSP directive. Only set to false
# AFTER rebuilding the frontend with INLINE_RUNTIME_CHUNK=false (removes
# CRA's inlined runtime script — the only reason 'unsafe-inline' is needed).
CSP_INLINE_SCRIPT=true

# ── Attachment limits ────────────────────────────────────────────────────────
# Per-file size cap in bytes (default: 25 MiB).
ATTACH_MAX_BYTES=26214400

# Maximum number of attachments per character (default: 50).
ATTACH_MAX_PER_CHAR=50

# Total attachment storage per character in bytes (default: 250 MiB).
ATTACH_MAX_TOTAL_BYTES=262144000

# ── First-run admin bootstrap ────────────────────────────────────────────────
# If set, an initial admin account is created on first launch (when no users
# exist). Remove or unset after the account is created — these are only read
# once and ignored thereafter.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=